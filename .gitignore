# 外部只读参考(软链 / 外部仓库,永不入库 —— 见 AGENTS.md §0.2)
references/

# Go 构建产物(`go build .` 在仓库根产出 bare 可执行文件 monkey-deck,不入库)
/monkey-deck
/bin/
/dist/
*.exe
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html

# 前端构建产物(node_modules 永不入库;lockfile 必须入库)
node_modules/
frontend/dist/
*.app
# 移动端(本项目不支持;wails3 update build-assets 会重建 build/ios build/android,删掉并忽略)
build/ios/
build/android/
# Taskfile 运行缓存
.task/

# 本地数据 / 日志(SQLite 是运行时数据,不入库)
*.db
*.sqlite
*.sqlite3
*.log

# 编辑器 / 系统
.DS_Store
.idea/
.vscode/
*.swp

# Wails 生成的 bindings(`wails3 gen bindings` 重新生成,属中间产物,不入库)
frontend/bindings/
