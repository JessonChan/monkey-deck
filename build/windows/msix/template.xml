<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="monkey-deck.exe"
        Arguments=""
        InstallLocation="C:\Program Files\jessonchan\Monkey Deck">
    </Installer>
    <PackageInformation
        PackageName="Monkey Deck"
        PackageDisplayName="Monkey Deck"
        PublisherName="CN=jessonchan"
        PublisherDisplayName="jessonchan"
        Version="0.1.0.0"
        PackageDescription="Pure ACP desktop client for coding agents">
        <Capabilities>
            <Capability Name="runFullTrust" />
        </Capabilities>
        <Applications>
            <Application
                Id="com.jessonchan.monkeydeck"
                Description="Pure ACP desktop client for coding agents"
                DisplayName="Monkey Deck"
                ExecutableName="monkey-deck.exe"
                EntryPoint="Windows.FullTrustApplication"
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Monkey Deck</DisplayName>
            <PublisherDisplayName>jessonchan</PublisherDisplayName>
            <Description>Pure ACP desktop client for coding agents</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="monkey-deck.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
